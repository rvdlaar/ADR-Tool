# Example environment configuration
# Copy to .env and fill in your values

# Security - REQUIRED IN PRODUCTION
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Comma-separated list of allowed origins
# In production, ONLY list the domains that need access
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Development mode
ENVIRONMENT=development

# Valid API Keys (comma-separated)
VALID_API_KEYS=

# Application
APP_NAME=ADR Tool API
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (future)
# DATABASE_URL=postgresql://user:pass@localhost/adr
