# ADR Tool — Environment Configuration
# Copy to .env and set your values

# =============================================================================
# AI (required for generation)
# =============================================================================
AI_API_KEY=
AI_PROVIDER=openai                    # openai, openrouter, ollama
AI_MODEL=gpt-4o-mini                  # Generation model
AI_BASE_URL=                          # For alternative providers (e.g., http://localhost:11434/v1)
EMBEDDING_MODEL=text-embedding-3-small # Embedding model for RAG

# =============================================================================
# RAG / Vector Store
# =============================================================================
CHROMA_URL=http://chromadb:8000       # ChromaDB URL (set by docker-compose)

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=CHANGE_ME_IN_PRODUCTION    # JWT signing key — use: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:8000  # Comma-separated allowed CORS origins
VALID_API_KEYS=                       # Comma-separated API keys for server-to-server auth

# =============================================================================
# Application
# =============================================================================
APP_NAME=ADR Tool
APP_VERSION=1.1.0
ENVIRONMENT=development               # development (enables /docs) or production
RATE_LIMIT_PER_MINUTE=60
DEBUG=false
PORT=8000
